# This .gitignore file is custom-tailored for Unity projects.
# It excludes heavy, temporary, and user-specific files that shouldn't be shared.

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Memory captures
/[Mm]emoryCaptures/

# Asset store packages (usually not tracked, can be re-downloaded)
/[Aa]ssets/AssetStoreTools*

# Autogenerated VS/MD solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# Unity secondary files
Assets/Tilemap/TilemapInfo.asset
Assets/Tilemap/TilemapInfo.asset.meta

# Crashlytics generated file
crashlytics-build.properties

# OS-generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
